#include <stdio.h>
#include <arpa/inet.h>
#include <unistd.h>

int main()
{
    int sfd;
    char buf[100];

    sfd = socket(AF_INET,
                 SOCK_DGRAM,0);

    struct sockaddr_in server;

    server.sin_family = AF_INET;
    server.sin_port = htons(5000);
    server.sin_addr.s_addr = INADDR_ANY;

    bind(sfd,
        (struct sockaddr*)&server,
        sizeof(server));

    recvfrom(sfd,buf,sizeof(buf),
             0,NULL,NULL);

    printf("Received: %s\n",buf);

    close(sfd);

    return 0;
}
