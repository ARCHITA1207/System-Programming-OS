#include<stdio.h>
#include<fcntl.h>
#include<unistd.h>
int main()
{
    int fd;
    char msg[] = "Hello Linux";
    fd = open("test.txt", O_CREAT | O_WRONLY, 0644);
    if(fd == -1)
    {
        printf("Error opening file\n");
        return 1;
    }
    write(fd, msg, sizeof(msg)-1);
    close(fd);
    printf("File created and data stored\n");
    return 0;
}
